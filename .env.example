# Solana RPC endpoint (required)
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Wallet: set ONE of the following (USER_KEYPAIR takes precedence).
# If neither is set, the bot falls back to ~/.config/solana/id.json.
# Path to a JSON secret-key file (solana-keygen format)
USER_KEYPAIR=/home/you/.config/solana/id.json
# BIP39 mnemonic phrase
#SOLANA_MNEMONIC=

# Execute real trades. false = simulation mode (quotes only, no swaps)
ENABLE_TRADING=false

# Optional: Jupiter API base URL
#JUPITER_API_BASE_URL=https://quote-api.jup.ag/v6

# Optional strategy overrides (defaults shown)
#MM_WAIT_TIME_MS=60000
#MM_SLIPPAGE_BPS=50
#MM_PRICE_TOLERANCE=0.02
#MM_REBALANCE_PERCENTAGE=0.5
#MM_MINIMUM_TRADE_AMOUNT=0.01
